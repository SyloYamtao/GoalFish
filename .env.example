# 推荐使用VOLCENGINECodingPlan的GLM-5.2模型
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=
LLM_CHAT_PROTOCOL=openai
# 当前 LLM 服务是否支持 OpenAI response_format={"type":"json_object"}。
# 火山方舟 Coding Plan /api/coding/v3 当前请求返回不支持时设为 false。
LLM_RESPONSE_FORMAT_JSON_OBJECT_SUPPORTED=false
# LLM 调试日志：打印所有 OpenAI-compatible chat.completions 请求和响应详情
# 会记录完整 messages 内容，仅建议本地调试开启；设置为 false 可关闭
LLM_LOG_COMPLETIONS=true
GOALFISH_LOG_COLOR=1
# 后端日志级别：排障时建议 DEBUG；稳定运行时可把 CONSOLE 改成 INFO
# 后端启动后会把完整控制台输出镜像写入项目根目录 logs/<启动时间>.log
GOALFISH_LOG_LEVEL=DEBUG
GOALFISH_CONSOLE_LOG_LEVEL=DEBUG
GOALFISH_FILE_LOG_LEVEL=DEBUG
# ===== 任务事件化与持久化 =====
# docker compose 默认启动同名 postgres/redis；源码启动时可改为本地服务地址
DATABASE_URL=postgresql+psycopg://goalfish:goalfish@localhost:5432/goalfish
SQLALCHEMY_ECHO=false
TASK_WORKFLOW_AUTO_CREATE_TABLES=true
TASK_WORKFLOW_FAIL_OPEN=true
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_DEFAULT_QUEUE=goalfish
WORKFLOW_EVENT_MAX_RETRIES=2
WORKFLOW_EVENT_RETRY_BACKOFF_SECONDS=30
# Step3 异步推演如果 Celery backend 长时间停留在 RETRY/RUNNING 且没有落库进展，状态接口会把 run 标记失败，避免页面永久卡住。
PREDICTION_ASYNC_STALE_SECONDS=1800
GRAPH_BUILD_EXECUTOR=celery
# thinking/reasoning 模型兼容：
# disabled（默认）会主动关闭 thinking，避免只返回 reasoning_content 而 content 为空。
# auto 只对已知模型自动关闭；enabled/false/off 不注入关闭 thinking 参数。
LLM_DISABLE_THINKING=disabled
# ===== 图谱后端配置 =====
# 使用开源 Graphiti + 本地 Neo4j
GRAPH_BACKEND=graphiti
# ===== Graphiti + Neo4j 配置 =====
# docker compose 会启动同密码的 neo4j 服务；源码启动时也可使用本地 Neo4j
GRAPHITI_NEO4J_URI=bolt://localhost:7687
GRAPHITI_NEO4J_USER=neo4j
GRAPHITI_NEO4J_PASSWORD=goalfish-graphiti
# Graphiti LLM 配置；留空时复用上面的 LLM_* 配置
GRAPHITI_LLM_API_KEY=
GRAPHITI_LLM_BASE_URL=
GRAPHITI_LLM_MODEL=
# Graphiti embedding 配置；请配置为你的 OpenAI-compatible embedding 服务
# 如果留空 API key/base_url，会复用 LLM_API_KEY/LLM_BASE_URL
GRAPHITI_EMBEDDING_PROVIDER=ollama
GRAPHITI_OLLAMA_EMBED_URL=http://127.0.0.1:11434/api/embed
GRAPHITI_EMBEDDING_API_KEY=
GRAPHITI_EMBEDDING_BASE_URL=
GRAPHITI_EMBEDDING_MODEL=qwen3-embedding:0.6b
GRAPHITI_EMBEDDING_DIM=1024
GRAPHITI_OLLAMA_MAX_CONCURRENCY=10
# 默认保留 Graphiti 抽取出的非本体关系；只有需要严格本体白名单图谱时才设为 true。
GRAPHITI_DELETE_NON_ONTOLOGY_EDGES=false
# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
